# Dependencies
# Ignore all node_modules directories from all sub-projects
**/node_modules/

# Build artifacts
# Ignore build output from Vite projects (admin, frontend)
**/dist/

# TypeScript
# Ignore TypeScript build cache files
**/*.tsbuildinfo

# Environment Variables
# Ignore sensitive environment files
.env
.env.*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Operating System files
.DS_Store
Thumbs.db
